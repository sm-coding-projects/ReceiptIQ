# Database
POSTGRES_USER=receipt_user
POSTGRES_PASSWORD=receipt_pass
POSTGRES_DB=receipt_db
DATABASE_URL=postgresql://receipt_user:receipt_pass@db:5432/receipt_db

# Redis
REDIS_URL=redis://redis:6379/0

# Security
SECRET_KEY=change-me-in-production-use-a-real-secret-key-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# File Upload
MAX_UPLOAD_SIZE=10485760
UPLOAD_DIR=/app/uploads
ALLOWED_EXTENSIONS_STR=jpg,jpeg,png,gif,bmp,tiff,pdf

# Frontend
VITE_API_URL=/api

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:80
